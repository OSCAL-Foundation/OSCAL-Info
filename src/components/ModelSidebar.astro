---
import type { MetaschemaDefinition, ModelEntry } from '../lib/metaschema';

interface Props {
  base: string;
  version: string;
  modelSlug: string;
  format: 'json' | 'xml';
  models: ModelEntry[];
  definitions: MetaschemaDefinition[];
}

const { base, version, modelSlug, format, models, definitions } = Astro.props;

const assemblies = definitions.filter((d) => d.type === 'assembly');
const fields = definitions.filter((d) => d.type === 'field');
---

<aside class="sidebar">
  <div class="sidebar-section">
    <div class="sidebar-title">Models</div>
    {
      models.map(({ slug, displayName }) => (
        <a
          href={`${base}${version}/${slug}/${format}/`}
          class:list={['sidebar-link', slug === modelSlug && 'active']}
        >
          {displayName}
        </a>
      ))
    }
  </div>

  {
    assemblies.length > 0 && (
      <div class="sidebar-section">
        <div class="sidebar-title">Assemblies</div>
        {assemblies.map((def) => (
          <a href={`#${def.name}`} class="sidebar-link">
            {def.formalName || def.name}
          </a>
        ))}
      </div>
    )
  }

  {
    fields.length > 0 && (
      <div class="sidebar-section">
        <div class="sidebar-title">Fields</div>
        {fields.map((def) => (
          <a href={`#${def.name}`} class="sidebar-link">
            {def.formalName || def.name}
          </a>
        ))}
      </div>
    )
  }
</aside>
